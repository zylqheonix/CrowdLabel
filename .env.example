# Copy to `.env` and adjust for local development.
# Never commit `.env` — it is gitignored.

# Required when DJANGO_DEBUG=False (production / shared beta host).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Local dev: True. Shared beta / production: False
DJANGO_DEBUG=True

# Comma-separated hostnames (no scheme). Example for a dept server:
# DJANGO_ALLOWED_HOSTS=crowdlabel.yourdept.edu,localhost,127.0.0.1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# HTTPS origins for CSRF (include scheme). Example:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://crowdlabel.yourdept.edu
DJANGO_CSRF_TRUSTED_ORIGINS=

# HTTPS security (auto-enabled when DJANGO_DEBUG=False). Set DJANGO_SECURE_HTTPS=True
# locally only if you terminate TLS in front of the app.
# DJANGO_SECURE_HTTPS=True
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_USE_PROXY_SSL_HEADER=True

# CSV upload caps
# CSV_UPLOAD_MAX_BYTES=2621440
# CSV_UPLOAD_MAX_ROWS=10000
# CSV_CHOICES_MAX_BYTES=8192

# Database
# Leave empty for local SQLite.
# For hosted Postgres, set full URL, e.g.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
DJANGO_DB_CONN_MAX_AGE=600

# Rate limiting cache (default: in-process LocMem). Use Redis/Memcached when running
# multiple gunicorn workers so limits apply across processes, e.g.
# DJANGO_CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# DJANGO_CACHE_LOCATION=redis://127.0.0.1:6379/1

# Email (OTP delivery)
# Local default is console backend. For real inbox delivery, use SMTP:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=CrowdLabel <noreply@crowdlabel.local>
DJANGO_EMAIL_HOST=
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
